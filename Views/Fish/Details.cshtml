@using FishingBuddy.Models
@model FishingBuddy.Models.Fish
@{
    ViewData["Title"] = Model.SpeciesName;
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Početna", "/"),
        ("Ribe", "/Fish"),
        (Model.SpeciesName, null)
    };

    var favouriteBait = ViewBag.FavouriteBait as Bait;
    var matchingSpots = ViewBag.CommonCatchSpots as List<FishingSpot> ?? new List<FishingSpot>();
    var equipment = Model.Equipment;
}

<section class="card fb-white-pill-card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h1 class="h2 mb-3">@Model.SpeciesName</h1>
        <dl class="row mb-0">
            <dt class="col-sm-3">Naziv vrste</dt>
            <dd class="col-sm-9">@Model.SpeciesName</dd>

            <dt class="col-sm-3">Sezona ulova</dt>
            <dd class="col-sm-9"><span class="badge bg-success">@Model.CatchSeason.GetDisplayName()</span></dd>

            <dt class="col-sm-3">Omiljeni mamac</dt>
            <dd class="col-sm-9">@(favouriteBait?.BaitName ?? "(nepoznato)")</dd>

            <dt class="col-sm-3">Boja mesa</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.FleshColor.GetDisplayName()</span></dd>

            <dt class="col-sm-3">Preferirana tehnika</dt>
            <dd class="col-sm-9">@Model.PreferredMethod.TechniqueName</dd>
        </dl>

        <div class="row g-4 mt-1">
            <div class="col-lg-6">
                <h2 class="h5">Česta mjesta ulova</h2>
                @if (matchingSpots.Count > 0)
                {
                    <ul class="list-group list-group-flush fb-white-pill-card rounded overflow-hidden">
                        @foreach (var spot in matchingSpots)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <div class="fw-semibold">@spot.SpotName</div>
                                    <div class="text-muted small">@spot.Region</div>
                                </div>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="FishingSpot" asp-action="Details" asp-route-id="@spot.SpotID">Detalji</a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">Nema evidentiranih lokacija za ovu vrstu ribe.</p>
                }
            </div>

            <div class="col-lg-6">
                <h2 class="h5">Oprema</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Rola</dt>
                    <dd class="col-sm-8">@equipment.FReel.Type.GetDisplayName(), veličina @equipment.FReel.Size</dd>

                    <dt class="col-sm-4">Štap</dt>
                    <dd class="col-sm-8">@equipment.FRod.LengthMeters.ToString("0.0#") m, @equipment.FRod.Action.GetDisplayName(), @equipment.FRod.MinWeightRatingGrams-@equipment.FRod.MaxWeightRatingGrams g</dd>

                    <dt class="col-sm-4">Najlon</dt>
                    <dd class="col-sm-8">@equipment.FLine.Type.GetDisplayName(), @equipment.FLine.ThicknessMm.ToString("0.00") mm</dd>
                </dl>
            </div>
        </div>
    </div>
</section>

<a class="btn btn-outline-secondary btn-sm" asp-controller="Fish" asp-action="Index">Natrag na popis riba</a>