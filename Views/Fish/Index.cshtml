@model IReadOnlyList<FishingBuddy.Models.Fish>
@{
    ViewData["Title"] = "Vrste riba";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Početna", "/")
    };
}

<section class="card shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h2 mb-0">Vrste riba</h1>
            <span class="badge bg-primary">@Model.Count vrsta</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Naziv vrste</th>
                        <th scope="col">Preferirana tehnika</th>
                        <th scope="col" class="text-end">Radnje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fish in Model)
                    {
                        <tr>
                            <td>@fish.SpeciesName</td>
                            <td>@fish.PreferredMethod.TechniqueName</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Fish" asp-action="Details" asp-route-id="@fish.FishID">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>