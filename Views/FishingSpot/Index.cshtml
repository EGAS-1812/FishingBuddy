@model IReadOnlyList<FishingBuddy.Models.FishingSpot>
@{
    ViewData["Title"] = "Ribolovna mjesta";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>
    {
        ("Početna", "/")
    };
}

<section class="card shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h2 mb-0">Ribolovna mjesta</h1>
            <span class="badge bg-primary">@Model.Count mjesta</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Naziv</th>
                        <th scope="col">Regija</th>
                        <th scope="col" class="text-end">Radnje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var spot in Model)
                    {
                        <tr>
                            <td>@spot.SpotName</td>
                            <td>@spot.Region</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="FishingSpot" asp-action="Details" asp-route-id="@spot.SpotID">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>