@model FishingBuddy.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "FishingBuddy";
    ViewData["BreadcrumbItems"] = new List<(string, string?)>();

    var statCards = new[]
    {
        new { Label = "Tehnike", Count = Model.TechniqueCount, Controller = "Technique", Accent = "primary" },
        new { Label = "Mamci", Count = Model.BaitCount, Controller = "Bait", Accent = "success" },
        new { Label = "Vrste riba", Count = Model.FishCount, Controller = "Fish", Accent = "info" },
        new { Label = "Evidencija ulova", Count = Model.CatchRecordCount, Controller = "CatchRecord", Accent = "warning" },
        new { Label = "Ribari", Count = Model.UserCount, Controller = "User", Accent = "dark" },
        new { Label = "Ribolovna mjesta", Count = Model.FishingSpotCount, Controller = "FishingSpot", Accent = "secondary" }
    };

    var techniqueName = Model.SearchResult?.RecommendedTechnique?.TechniqueName ?? "N/A";
    var baitName = Model.SearchResult?.RecommendedBait?.BaitName ?? "N/A";
}

<section class="fb-home-search-panel rounded-4 border p-4 p-lg-5 mb-4">
    <div class="fb-home-hero-head text-center">
        <h1 class="fb-home-hero-title display-4 fw-bold">FishingBuddy</h1>
        <p class="fb-home-hero-tagline lead fst-italic mb-0">Your #1 Fishing application</p>
    </div>
    <div class="fb-home-hero-visual" aria-hidden="true">
        <div class="fb-home-hero-pill">
            <svg class="fb-home-hero-fish" viewBox="0 0 640 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation" focusable="false">
                <defs>
                    <linearGradient id="fbFishBody" x1="128" y1="60" x2="515" y2="158" gradientUnits="userSpaceOnUse">
                        <stop offset="0" stop-color="#CFEFFF" />
                        <stop offset="0.48" stop-color="#6EC0F0" />
                        <stop offset="1" stop-color="#1E6DAD" />
                    </linearGradient>
                    <linearGradient id="fbFishFin" x1="252" y1="54" x2="361" y2="166" gradientUnits="userSpaceOnUse">
                        <stop offset="0" stop-color="#F4FBFF" stop-opacity="0.92" />
                        <stop offset="1" stop-color="#3F93CE" stop-opacity="0.88" />
                    </linearGradient>
                    <linearGradient id="fbFishTail" x1="42" y1="65" x2="138" y2="159" gradientUnits="userSpaceOnUse">
                        <stop offset="0" stop-color="#84D2FF" />
                        <stop offset="1" stop-color="#14558A" />
                    </linearGradient>
                </defs>
                <ellipse cx="320" cy="110" rx="260" ry="64" fill="rgba(196, 233, 255, 0.14)" />
                <path d="M129 110C164 71 229 49 324 56C390 61 455 80 505 110C455 140 390 159 324 164C229 171 164 149 129 110Z" fill="url(#fbFishBody)" />
                <path d="M129 110L47 60L63 110L47 160L129 110Z" fill="url(#fbFishTail)" />
                <path d="M269 69C294 41 332 34 369 48C344 61 323 75 305 100L269 69Z" fill="url(#fbFishFin)" fill-opacity="0.95" />
                <path d="M284 148C312 129 348 127 385 141C354 151 328 166 307 187L284 148Z" fill="url(#fbFishFin)" fill-opacity="0.82" />
                <path d="M360 76C406 84 447 97 474 110C447 123 406 136 360 144" stroke="rgba(244, 251, 255, 0.52)" stroke-width="8" stroke-linecap="round" />
                <path d="M385 83C402 91 412 100 412 110C412 120 402 129 385 137" stroke="#0D3E67" stroke-opacity="0.38" stroke-width="4" stroke-linecap="round" />
                <circle cx="447" cy="101" r="8" fill="#F8FDFF" fill-opacity="0.98" />
                <circle cx="449" cy="101" r="3.5" fill="#123A60" />
                <path d="M496 113C506 113 514 116 520 122" stroke="#0E3B62" stroke-opacity="0.48" stroke-width="4" stroke-linecap="round" />
            </svg>
        </div>
    </div>
    <div class="row justify-content-center fb-home-search-row">
        <div class="col-lg-10 col-xl-8 mx-auto">
            <form asp-action="Index" asp-controller="Home" method="get" class="fb-search-form" role="search" aria-label="Pretraga riba">
                <div class="input-group input-group-lg">
                    <input id="fishName"
                           name="fishName"
                           type="text"
                           class="form-control"
                           placeholder="Brancin, Orada, Strijelka..."
                           value="@Model.SearchTerm"
                           aria-label="Pretraži ribu po nazivu" />
                    <button type="submit" class="btn btn-primary px-4">GoFish</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4">
        @if (Model.SearchPerformed && Model.SearchResult is null)
        {
            <div class="alert alert-warning mb-0" role="alert">
                    Nije pronađena riba za unos: <strong>@Model.SearchTerm</strong>. Pokušaj s drugim nazivom.
            </div>
        }
        else if (Model.SearchPerformed && Model.SearchResult is { } searchResult)
        {
            <section class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                        <h2 class="h3 mb-0">@searchResult.Fish.SpeciesName</h2>
                        <span class="badge text-bg-primary fb-season-badge">Sezona: @searchResult.Fish.CatchSeason.GetDisplayName()</span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6 col-xl-4">
                            <div class="fb-white-pill-card p-3 rounded-3 bg-light h-100">
                                <div class="small text-uppercase text-muted mb-1">Tehnika</div>
                                <div class="fw-semibold">@techniqueName</div>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-4">
                            <div class="fb-white-pill-card p-3 rounded-3 bg-light h-100">
                                <div class="small text-uppercase text-muted mb-1">Mamac</div>
                                <div class="fw-semibold">@baitName</div>
                            </div>
                        </div>
                        <div class="col-xl-4">
                            <div class="fb-white-pill-card p-3 rounded-3 bg-light h-100">
                                <div class="small text-uppercase text-muted mb-1">Oprema</div>
                                <div class="fw-semibold">Preporučena oprema: @techniqueName + @baitName</div>
                            </div>
                        </div>
                    </div>

                    <h3 class="h5 mb-2">Preporučena mjesta</h3>
                    @if (searchResult.RecommendedSpots.Any())
                    {
                        <ul class="list-group list-group-flush rounded-3 border overflow-hidden">
                            @foreach (var spot in searchResult.RecommendedSpots)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <span>
                                        <strong>@spot.SpotName</strong>
                                        <span class="text-muted">(@spot.Region)</span>
                                    </span>
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="FishingSpot" asp-action="Details" asp-route-id="@spot.SpotID">Pogledaj mjesto</a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Nema preporučenih mjesta za ovu ribu.</p>
                    }
                </div>
            </section>
        }
    </div>
</section>

<section class="mb-4">
    <div class="row g-3">
        @foreach (var statCard in statCards)
        {
            <div class="col-md-6 col-xl-4">
                <a class="text-decoration-none" asp-controller="@statCard.Controller" asp-action="Index">
                    <div class="card fb-white-pill-card fb-home-stat-card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <span class="text-uppercase text-muted small d-block mb-2">@statCard.Label</span>
                            <div class="fb-stat-card-content d-flex flex-column h-100">
                                <span class="display-6 fw-semibold text-dark mb-auto">@statCard.Count</span>
                                <div class="fb-stat-card-footer text-end">
                                    <span class="badge fb-stat-card-cta bg-@statCard.Accent">Prikaži sve</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<section class="card fb-white-pill-card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">Nedavni ulovi</h2>
            <a class="btn btn-sm btn-outline-primary" asp-controller="CatchRecord" asp-action="Index">Sva evidencija ulova</a>
        </div>

        @if (Model.RecentCatches.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-bordered table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Datum</th>
                            <th scope="col">Lokacija</th>
                            <th scope="col">Težina (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var catchRecord in Model.RecentCatches)
                        {
                            <tr>
                                <td>@catchRecord.CatchDate.ToString("dd.MM.yyyy")</td>
                                <td>@catchRecord.Location</td>
                                <td>@catchRecord.Weight.ToString("0.##")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Još nema zabilježenih ulova.</p>
        }
    </div>
</section>

<section class="card fb-white-pill-card shadow-sm border-0">
    <div class="card-body">
        <h2 class="h4 mb-3">Brza navigacija</h2>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-primary" asp-controller="FishingSpot" asp-action="Index">Ribolovna mjesta</a>
            <a class="btn btn-outline-primary" asp-controller="Fish" asp-action="Index">Ribe</a>
            <a class="btn btn-outline-primary" asp-controller="CatchRecord" asp-action="Index">Evidencija ulova</a>
            <a class="btn btn-outline-primary" asp-controller="Bait" asp-action="Index">Mamci</a>
            <a class="btn btn-outline-primary" asp-controller="Technique" asp-action="Index">Tehnike</a>
            <a class="btn btn-outline-primary" asp-controller="User" asp-action="Index">Ribari</a>
        </div>
    </div>
</section>
